{
  "name": "create-rsmax",
  "version": "1.1.6",
  "description": "Create Rsmax apps with no build configuration.",
  "bin": {
    "create-rsmax": "./bin/create-rsmax"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "format": "prettier --write .",
    "test": "rstest run",
    "test-build": "node ./bin/create-rsmax demo ali",
    "prepare": "npm run build && simple-git-hooks"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/watsonhaw5566/create-rsmax"
  },
  "keywords": [
    "Remax",
    "Rsmax",
    "React",
    "CLI"
  ],
  "authors": [
    "QC-L",
    "watsonhaw"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/watsonhaw5566/create-rsmax/issues"
  },
  "files": [
    "lib",
    "bin",
    "templates"
  ],
  "homepage": "https://github.com/watsonhaw5566/create-rsmax#readme",
  "dependencies": {
    "chalk": "^4.1.0",
    "ejs": "^3.1.10",
    "metalsmith": "^2.3.0",
    "prompts": "^2.4.0",
    "semver": "^7.3.4",
    "yargs": "^16.2.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.6.9",
    "@rstest/core": "^0.10.3",
    "@types/ejs": "^3.0.5",
    "@types/node": "^20",
    "@types/prompts": "^2.0.9",
    "@types/yargs": "^16.0",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run format && npm run test && npm run build"
  },
  "engines": {
    "node": ">= 20.19"
  }
}
